# Auto convert line endings to LF for all text files
* text=auto

# JavaScript/TypeScript
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf

# Shell
*.sh text eol=lf
*.bash text eol=lf

# Windows
*.bat eol=crlf
*.cmd eol=crlf
*.ps1 eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.gz binary
*.zip binary
*.7z binary
*.ttf binary
*.otf binary
*.db binary
