# ============================================
# ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in your values

# Node Environment
NODE_ENV=development

# ============================================
# OPTIONAL: Gemini AI Configuration
# ============================================
# Uncomment to enable AI-powered link analysis
# GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Path to SQLite database (defaults to ./database/live.db)
# DB_PATH=./database/live.db

# ============================================
# SECURITY & CORS CONFIGURATION
# ============================================
# Trust X-Forwarded-For header only in production behind a trusted proxy
TRUST_PROXY=false

# Comma-separated list of allowed CORS origins
# Defaults to: http://localhost:3000,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================
# SERVER CONFIGURATION
# ============================================
# Server port (defaults to 3000)
PORT=3000

# Server host
HOST=0.0.0.0
